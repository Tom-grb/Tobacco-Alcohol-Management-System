{
  "bsonType": "object",
  "required": ["username", "password"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": { "description": "ID，系统自动生成" },
    "username": {
      "bsonType": "string",
      "description": "用户名",
      "title": "用户名",
      "trim": "both"
    },
    "password": {
      "bsonType": "string",
      "description": "密码（加密后）",
      "title": "密码"
    },
    "register_date": {
      "bsonType": "timestamp",
      "description": "注册时间",
      "forceDefaultValue": { "$env": "now" }
    },
    "last_login_date": {
      "bsonType": "timestamp",
      "description": "最后登录时间"
    }
  },
  "indexes": [
    {
      "keys": { "username": 1 },
      "unique": true
    }
  ]
}
